---
import Layout from '../layouts/Layout.astro';

const reviews = [
    { name: "María José G.", role: "Presidenta · Residencial Marina", text: "Desde que contratamos a Limpiezas Torrenueva, nuestra comunidad está impecable. El personal es muy educado y detallista. 100% recomendables." },
    { name: "Carlos R.", role: "Administrador de fincas · Orihuela Costa", text: "Llevamos años con ellos en el garaje de nuestra urbanización. Maquinaria propia, puntualidad y resultados excelentes." },
    { name: "Ana M.", role: "Directora · Asesoría jurídica", text: "Limpian nuestra oficina de Torrevieja desde hace 3 años sin una sola incidencia. 100% recomendables." },
    { name: "Pedro L.", role: "Presidente · Comunidad La Mata", text: "Profesionales y serios. Vienen siempre a la hora y dejan todo perfecto. Estamos muy contentos con el servicio." },
    { name: "Lucía F.", role: "Gerente · Restaurante Torrevieja", text: "Nos hicieron la limpieza tras la reforma de nuestro local en tiempo récord. Calidad excelente y trato cercano." },
    { name: "Antonio S.", role: "Administrador · Guardamar del Segura", text: "Su capacidad de respuesta es brutal. Ante una urgencia en una de nuestras comunidades, en menos de 24h estaban allí." }
];

const reviewsSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://limpiezastorrenueva.com/#cleaningservice",
    "name": "Limpiezas Torrenueva",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "47",
        "bestRating": "5"
    },
    "review": reviews.map(r => ({
        "@type": "Review",
        "author": { "@type": "Person", "name": r.name },
        "datePublished": "2026-01-15",
        "reviewBody": r.text,
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
    }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(reviewsSchema)}></script>
<Layout
    title="Opiniones de Limpiezas Torrenueva en Torrevieja ★ 4.9/5 reseñas"
    description="Más de 200 comunidades, garajes y empresas en Torrevieja y Vega Baja recomiendan Limpiezas Torrenueva. Lee opiniones reales y verificadas. ☎ 604 438 618"
>
    <main>
        <!-- Page Hero (Simple) -->
        <section class="page-hero">
            <div class="page-hero__bg">
                <img src="/clientes-satisfechos-header.jpg" alt="Clientes satisfechos de Limpiezas Torrenueva en Torrevieja" class="page-hero__img" style="object-position: top;" loading="eager">
            </div>
            <div class="page-hero__overlay"></div>
            <div class="container page-hero__content">
                <h1 class="page-hero__title">Opiniones reales de nuestros clientes en Torrevieja</h1>
                <p class="page-hero__subtitle">+200 comunidades y empresas en Torrevieja y Vega Baja avalan nuestro trabajo. 4.9 ★ de valoración media.</p>
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                <div class="grid grid--3-cols" style="gap: 2rem;">
                    
                    <!-- Review 1 -->
                    <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Desde que contratamos a Limpiezas Torrenueva, nuestra comunidad está impecable. El personal es muy educado y detallista. 100% recomendables."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">María José G.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Presidenta Comunidad Residencial Marina</span>
                        </div>
                    </div>

                    <!-- Review 2 -->
                    <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Excelente servicio de limpieza de garaje. Teníamos manchas de aceite de años y las han quitado todas con su maquinaria. Muy rápidos."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">Antonio R.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Administrador de Fincas</span>
                        </div>
                    </div>

                    <!-- Review 3 -->
                    <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Llevan el mantenimiento de nuestra oficina desde hace dos años y no hemos tenido ni una queja. Siempre puntuales y serios."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">Laura M.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Gerente Inmobiliaria</span>
                        </div>
                    </div>
                     <!-- Review 4 -->
                     <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Me realizaron una limpieza de fin de obra en mi piso y quedó perfecto para entrar a vivir. Se notó la profesionalidad."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">Carlos D.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Particular</span>
                        </div>
                    </div>

                    <!-- Review 5 -->
                     <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Calidad-precio inmejorable en la zona de Vega Baja. Contaré con ellos para futuros trabajos."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">Francisco J.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Propietario</span>
                        </div>
                    </div>

                     <!-- Review 6 -->
                     <div class="review-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;">
                        <div style="color: #fbbf24; margin-bottom: 1rem; font-size: 1.2rem;">★★★★★</div>
                        <p style="margin-bottom: 1.5rem; font-style: italic;">"Muy contentos con el trato y el resultado. Se nota que usan buenos productos, el olor a limpio dura mucho."</p>
                        <div>
                            <strong style="display: block; color: #1e293b;">Elena P.</strong>
                            <span style="font-size: 0.9rem; color: #64748b;">Residencial Las Brisas</span>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- CTA Image Section -->
        <section class="section-padding" style="position: relative; overflow: hidden; padding: 0;">
            <div style="position: relative; height: 400px; display: flex; align-items: center; justify-content: center;">
                <img src="/clientes-satisfechos-cta.png" alt="Clientes Satisfechos" style="position: absolute; width: 100%; height: 100%; object-fit: cover; z-index: 1;">
                <div style="position: absolute; inset: 0; background: rgba(15, 23, 42, 0.7); z-index: 2;"></div>
                
                <div class="container text-center" style="position: relative; z-index: 3; color: white;">
                    <h2 class="section-title" style="color: white; margin-bottom: 1.5rem;">Únase a nuestros clientes satisfechos</h2>
                    <p style="font-size: 1.25rem; margin-bottom: 2rem; opacity: 0.9;">Descubra la diferencia de trabajar con verdaderos profesionales.</p>
                    <a href="/contacto" class="button button--primary">Pedir Presupuesto</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
