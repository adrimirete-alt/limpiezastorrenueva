</html>

<style is:global>
    .whatsapp-btn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 56px;
        height: 56px;
        background: #25d366;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4);
        z-index: 998;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .whatsapp-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 18px rgba(37, 211, 102, 0.55);
    }
    .whatsapp-btn svg { width: 30px; height: 30px; }
    .whatsapp-btn img { display: none; }

    .mobile-call-btn {
        display: none;
        position: fixed;
        bottom: 20px;
        left: 20px;
        right: 90px;
        background: #3b82f6;
        color: white;
        text-decoration: none;
        padding: 14px 20px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.95rem;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.45);
        z-index: 998;
        animation: pulse-call 2s infinite;
    }
    .mobile-call-btn:hover { background: #2563eb; }

    @keyframes pulse-call {
        0%, 100% { box-shadow: 0 4px 12px rgba(59, 130, 246, 0.45); }
        50% { box-shadow: 0 4px 20px rgba(59, 130, 246, 0.75); }
    }

    @media (max-width: 768px) {
        .mobile-call-btn { display: flex; }
        .whatsapp-btn { width: 52px; height: 52px; }
        .whatsapp-btn svg { width: 26px; height: 26px; }
    }

    @media print {
        .whatsapp-btn, .mobile-call-btn { display: none !important; }
    }

    *:focus-visible {
        outline: 3px solid #3b82f6;
        outline-offset: 2px;
        border-radius: 4px;
    }

    @media (max-width: 1024px) {
        .nav { display: none; }
        .nav.nav--open {
            display: flex !important;
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            width: 88%;
            max-width: 360px;
            background: white;
            flex-direction: column;
            padding: 5rem 1.5rem 2rem;
            box-shadow: -8px 0 30px rgba(0,0,0,0.15);
            z-index: 200;
            overflow-y: auto;
            animation: slide-in-nav 0.25s ease-out;
        }
        .nav.nav--open .nav__list {
            flex-direction: column;
            gap: 0.25rem;
            width: 100%;
        }
        .nav.nav--open .nav__item { width: 100%; }
        .nav.nav--open .nav__link {
            display: block;
            padding: 1rem 1.25rem;
            border-radius: 10px;
            font-size: 1.05rem;
            color: #1e293b;
        }
        .nav.nav--open .nav__link:hover { background: #f1f5f9; }
        .nav.nav--open::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(15, 23, 42, 0.55);
            z-index: -1;
        }
        .menu-toggle { display: flex; flex-direction: column; gap: 5px; background: transparent; border: none; cursor: pointer; padding: 0.5rem; z-index: 250; position: relative; }
        .menu-toggle__line { display: block; width: 26px; height: 2px; background: #1e293b; border-radius: 2px; transition: transform 0.2s; }
    }
    @media (min-width: 1025px) {
        .menu-toggle { display: none; }
    }
    @keyframes slide-in-nav {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
            scroll-behavior: auto !important;
        }
    }
</style>
