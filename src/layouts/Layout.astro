---
export interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: string;
    noindex?: boolean;
}

const {
    title = "Empresas de Limpieza en Torrevieja | Limpiezas Torrenueva",
    description = "Empresa de limpiezas en Torrevieja y Vega Baja. Especialistas en limpieza de comunidades, garajes, oficinas e industrial. Presupuesto sin compromiso. ☎ +34 604 438 618",
    image = "/og-image.jpg",
    type = "website",
    noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://limpiezastorrenueva.com').toString();
const ogImageURL = new URL(image, Astro.site || 'https://limpiezastorrenueva.com').toString();

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-CBQ5W2TETG';
---
<!DOCTYPE html>
<html lang="es-ES">
<head>
