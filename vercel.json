{
    "redirects": [
        {
            "source": "/:path*",
            "has": [{ "type": "host", "value": "limpiezastorrenueva.com" }],
            "destination": "https://www.limpiezastorrenueva.com/:path*",
            "permanent": true
        },
        { "source": "/maquinas", "destination": "/maquinaria", "permanent": true }
    ],
    "headers": [
        {
            "source": "/:path*.:ext(jpg|jpeg|png|webp|avif|svg|ico|woff|woff2|ttf)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/:sitemap(sitemap-.*).xml",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" },
                { "key": "Content-Type", "value": "application/xml" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        }
    ]
}
